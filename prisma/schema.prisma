datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Property {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  bhkType     String   // "1 BHK", "2 BHK", "3 BHK"
  status      String   // "Rent", "Sell"
  priceVal    Float
  priceStr    String
  location    String
  description String
  beds        Int
  baths       Int
  sqft        Int
  floor       Int      @default(1)
  age         String   @default("")
  image       String   // primary photo URL
  gallery     String   // Serialized JSON array of secondary image URLs
  amenities   String   // Serialized JSON array of amenity strings
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
